datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user")
  timezone      String    @default("UTC")
  medicines     Medicine[]
  logs          Log[]
  subscriptions PushSubscription[]
  accounts          Account[]
  sessions          Session[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  reminderAIs       ReminderAI[]
  doctors           DoctorAssignment[] @relation("Doctors")
  patientLinks      CaregiverLink[] @relation("PatientLinks")
  givenCareLinks    CaregiverLink[] @relation("GivenCareLinks")
  emergencyContacts EmergencyContact[]
}

model Medicine {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  dosage      String
  frequency   String     // daily, weekly, custom
  startDate   DateTime
  endDate     DateTime?
  schedules   Schedule[]
  logs        Log[]
  stockHistory StockHistory[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Schedule {
  id         String   @id @default(cuid())
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  time       String   // HH:mm
}

model Log {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicineId String
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  status     String   // taken, missed, skipped
  timestamp  DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// --- ADVANCED FEATURES ADDITIONS ---

model ReminderAI {
  id              String   @id @default(cuid())
  userId          String
  medicineId      String
  suggestedTime   String   
  adherenceScore  Float
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CaregiverLink {
  id              String   @id @default(cuid())
  caregiverId     String   
  patientId       String   
  permissions     String   
  createdAt       DateTime @default(now())

  patient         User     @relation(name: "PatientLinks", fields: [patientId], references: [id], onDelete: Cascade)
  caregiver       User     @relation(name: "GivenCareLinks", fields: [caregiverId], references: [id], onDelete: Cascade)
}

model DoctorAssignment {
  id              String   @id @default(cuid())
  doctorId        String
  patientId       String
  hospital        String?
  createdAt       DateTime @default(now())
  
  patient         User     @relation(name: "Doctors", fields: [patientId], references: [id], onDelete: Cascade)
}

model EmergencyContact {
  id              String   @id @default(cuid())
  userId          String
  name            String
  phone           String
  relation        String
  notifyThreshold Int      
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StockHistory {
  id              String   @id @default(cuid())
  medicineId      String
  quantityAdded   Int
  totalRemaining  Int
  createdAt       DateTime @default(now())
  medicine        Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
}
